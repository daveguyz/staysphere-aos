{%- assign lot_id = request.query_string | split: 'lot=' | last | split: '&' | first -%}
{%- assign sym    = settings.auction_currency_symbol | default: '$' -%}

<div class="auction-success-page page-width section-padding"
     id="auction-success-page"
     data-lot-id="{{ lot_id }}"
     data-api="{{ settings.api_gateway_url }}">

  {%- comment -%} ── Win state (default) ── {%- endcomment -%}
  <div class="auction-success-card" id="auction-success-card">

    <div class="auction-success-card__confetti" aria-hidden="true">🎊</div>
    <h1 class="auction-success-card__title" data-i18n="auction.sold">Congratulations — you won!</h1>

    <div class="auction-success-card__lot-summary" id="success-lot-summary">
      <div class="skeleton-line" aria-hidden="true"></div>
      <div class="skeleton-line skeleton-line--short" aria-hidden="true"></div>
    </div>

    <div class="auction-success-card__amount-row">
      <span class="auction-success-card__amount-label">Winning bid</span>
      <span class="auction-success-card__amount" id="success-winning-amount">
        <span class="skeleton-inline" aria-hidden="true"></span>
      </span>
    </div>

    {%- comment -%} Deposit status (JS fills based on lot configuration) ── {%- endcomment -%}
    <div class="auction-success-card__deposit-status" id="success-deposit-status"
         aria-live="polite"></div>

    {%- comment -%} Next steps ── {%- endcomment -%}
    <div class="auction-success-card__next-steps">
      <h2 class="auction-success-card__next-title" data-i18n="general.whats_next">What happens next</h2>
      <ol class="auction-success-card__steps-list">
        <li class="auction-success-card__step" id="step-deposit">
          <span class="auction-success-card__step-icon" aria-hidden="true">💳</span>
          <div>
            <p class="auction-success-card__step-title">Payment</p>
            <p class="auction-success-card__step-body" id="step-deposit-body">
              Your deposit has been applied. Our team will contact you to arrange
              the remaining balance.
            </p>
          </div>
        </li>
        <li class="auction-success-card__step">
          <span class="auction-success-card__step-icon" aria-hidden="true">📞</span>
          <div>
            <p class="auction-success-card__step-title">Seller contact</p>
            <p class="auction-success-card__step-body">
              The seller will reach out within 24 hours to confirm handover details.
            </p>
          </div>
        </li>
        <li class="auction-success-card__step">
          <span class="auction-success-card__step-icon" aria-hidden="true">🏠</span>
          <div>
            <p class="auction-success-card__step-title">Property handover</p>
            <p class="auction-success-card__step-body">
              Once full payment is complete you'll receive the title transfer documents and handover details.
            </p>
          </div>
        </li>
      </ol>
    </div>

    <div class="auction-success-card__actions">
      <a href="/account" class="btn btn--primary">View my account</a>
      <a href="/pages/auctions" class="btn btn--ghost">Browse more listings</a>
    </div>

    <p class="auction-success-card__support">
      Questions? <a href="/pages/contact">Contact support</a> — we're here to help.
    </p>

  </div>

  {%- comment -%} ── Loss / no-reserve fallback (shown by JS if status is LOST) ── {%- endcomment -%}
  <div class="auction-loss-card hidden" id="auction-loss-card">
    <div class="auction-loss-card__icon" aria-hidden="true">😔</div>
    <h1 class="auction-loss-card__title">Better luck next time</h1>
    <p class="auction-loss-card__sub">
      You weren't the winning bidder this time.
      Any deposit you placed will be released within 24 hours.
    </p>
    <a href="/pages/auctions" class="btn btn--primary">Browse more listings</a>
  </div>

</div>

{% schema %}
{
  "name": "Auction success",
  "settings": []
}
{% endschema %}
