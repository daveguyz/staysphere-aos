<section class="hero" id="hero-section">
  <div class="hero__media">
    {%- if section.settings.video_url != blank -%}
      <video class="hero__video" autoplay muted loop playsinline poster="{{ section.settings.image | image_url: width: 1600 }}">
        <source src="{{ section.settings.video_url }}" type="video/mp4">
      </video>
    {%- elsif section.settings.image != blank -%}
      <img src="{{ section.settings.image | image_url: width: 1920 }}"
           srcset="{{ section.settings.image | image_url: width: 800 }} 800w,
                   {{ section.settings.image | image_url: width: 1200 }} 1200w,
                   {{ section.settings.image | image_url: width: 1920 }} 1920w"
           sizes="100vw"
           alt="{{ section.settings.image.alt | default: shop.name }}"
           class="hero__image" loading="eager" fetchpriority="high">
    {%- else -%}
      <div class="hero__fallback-bg" aria-hidden="true"></div>
    {%- endif -%}
    <div class="hero__overlay" aria-hidden="true"></div>
  </div>

  <div class="hero__content page-width">
    {%- if section.settings.eyebrow != blank -%}
      <p class="hero__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    <h1 class="hero__heading">{{ section.settings.heading | default: 'Sell. Auction. Manage. Every property transaction in one place.' }}</h1>
    {%- if section.settings.subheading != blank -%}
      <p class="hero__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}

    {% comment %} Search widget — works in skeleton mode with form submit {% endcomment %}
    <div class="hero-search" id="hero-search-widget">
      <div class="hero-search__fields">
        <div class="hero-search__field hero-search__field--destination">
          <label for="hero-destination" class="hero-search__label" data-i18n="hero.search_where">Where</label>
          <input type="text" id="hero-destination" name="city"
                 placeholder="{{ section.settings.destination_placeholder | default: 'City, suburb, postcode…' }}"
                 data-i18n-placeholder="hero.ai_placeholder"
                 class="hero-search__input" autocomplete="off" spellcheck="false">
          <div class="hero-search__autocomplete" id="hero-autocomplete" role="listbox" aria-label="Destination suggestions" hidden></div>
        </div>

        <div class="hero-search__field hero-search__field--checkin">
          <label for="hero-checkin" class="hero-search__label">Check in</label>
          <input type="date" id="hero-checkin" name="checkIn"
                 min="{{ 'now' | date: '%Y-%m-%d' }}" class="hero-search__input">
        </div>

        <div class="hero-search__field hero-search__field--checkout">
          <label for="hero-checkout" class="hero-search__label">Check out</label>
          <input type="date" id="hero-checkout" name="checkOut" class="hero-search__input">
        </div>

        <div class="hero-search__field hero-search__field--guests">
          <label for="hero-guests" class="hero-search__label">Guests</label>
          <select id="hero-guests" name="guests" class="hero-search__input hero-search__input--select">
            {%- for i in (1..12) -%}
              <option value="{{ i }}">{{ i }} guest{% if i > 1 %}s{% endif %}</option>
            {%- endfor -%}
          </select>
        </div>

        <button class="hero-search__submit btn btn--primary" id="hero-search-btn" type="button">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
          <span data-i18n="hero.search_button">Search</span>
        </button>
      </div>

      {% if settings.search_show_ai_bar and settings.feature_ai_concierge %}
        <div class="hero-search__ai-bar">
          <span class="hero-search__ai-badge" aria-label="AI powered">✦ AI</span>
          <input type="text" id="hero-ai-input" class="hero-search__ai-input"
                 placeholder="Describe the property you’re looking for…"
                 data-i18n-placeholder="hero.ai_placeholder"
                 aria-label="Natural language property search">
          <button class="hero-search__ai-btn btn btn--ghost btn--sm" id="hero-ai-btn" type="button" data-i18n="hero.ai_button">Ask Concierge</button>
        </div>
      {% endif %}
    </div>

    {% comment %} Quick filter pills {% endcomment %}
    {%- if section.blocks.size > 0 -%}
      <div class="hero__pills" role="group" aria-label="Quick filters">
        {%- for block in section.blocks -%}
          {%- if block.type == 'filter_pill' -%}
            <button class="hero__pill" data-filter="{{ block.settings.filter_value }}"
                    data-filter-type="{{ block.settings.filter_type }}"
                    {{ block.shopify_attributes }}>
              {%- if block.settings.emoji != blank -%}
                <span aria-hidden="true">{{ block.settings.emoji }}</span>
              {%- endif -%}
              {{ block.settings.label }}
            </button>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Background image" },
    { "type": "text", "id": "video_url", "label": "Background video URL (.mp4)" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "Powered by StaySphere AOS" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Sell. Auction. Manage. Every property transaction in one place." },
    { "type": "textarea", "id": "subheading", "label": "Subheading" },
    { "type": "text", "id": "destination_placeholder", "label": "Destination placeholder" },
    { "type": "range", "id": "overlay_opacity", "min": 0, "max": 80, "step": 5, "unit": "%", "label": "Image overlay opacity", "default": 45 },
    { "type": "range", "id": "min_height", "min": 400, "max": 900, "step": 50, "unit": "px", "label": "Minimum height", "default": 600 }
  ],
  "blocks": [
    {
      "type": "filter_pill",
      "name": "Filter pill",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Pet-friendly" },
        { "type": "text", "id": "emoji", "label": "Emoji prefix", "default": "🐾" },
        { "type": "text", "id": "filter_type", "label": "Filter type", "info": "e.g. petFriendly, hasPool, city", "default": "petFriendly" },
        { "type": "text", "id": "filter_value", "label": "Filter value", "default": "true" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero",
      "blocks": [
        { "type": "filter_pill", "settings": { "label": "Pet-friendly", "emoji": "🐾", "filter_type": "petFriendly", "filter_value": "true" } },
        { "type": "filter_pill", "settings": { "label": "Pool", "emoji": "🏊", "filter_type": "hasPool", "filter_value": "true" } },
        { "type": "filter_pill", "settings": { "label": "For sale", "emoji": "🏠", "filter_type": "propertyType", "filter_value": "FOR_SALE" } },
        { "type": "filter_pill", "settings": { "label": "Auction", "emoji": "🔨", "filter_type": "propertyType", "filter_value": "AUCTION" } }
      ]
    }
  ]
}
{% endschema %}
