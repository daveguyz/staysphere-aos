{%- assign lot_id = request.query_string | split: 'lot=' | last | split: '&' | first -%}
{%- assign sym    = settings.auction_currency_symbol | default: '$' -%}

<div class="auction-success-page page-width section-padding"
     id="auction-success-page"
     data-lot-id="{{ lot_id }}"
     data-api="{{ settings.api_gateway_url }}">

  {%- comment -%} ── WIN STATE ── {%- endcomment -%}
  <div class="auction-success-card" id="auction-success-card">

    <div class="auction-success-card__confetti" aria-hidden="true">🎊</div>
    <h1 class="auction-success-card__title" data-i18n="auction.sold">Congratulations — you won!</h1>

    <div class="auction-success-card__lot-summary" id="success-lot-summary">
      <div class="skeleton-line" aria-hidden="true"></div>
      <div class="skeleton-line skeleton-line--short" aria-hidden="true"></div>
    </div>

    <div class="auction-success-card__amount-row">
      <span class="auction-success-card__amount-label">Winning bid</span>
      <span class="auction-success-card__amount" id="success-winning-amount">
        <span class="skeleton-inline" aria-hidden="true"></span>
      </span>
    </div>

    {%- comment -%} Agreement state machine — powered by plugin-auction-room.js {%- endcomment -%}
    <div class="success-agreement" id="success-agreement" aria-live="polite">
      <h2 class="success-agreement__title">Purchase agreement</h2>

      {%- comment -%} PENDING — agreement not generated yet {%- endcomment -%}
      <div class="success-agreement__state success-agreement__state--pending" id="agr-state-pending">
        <span class="success-agreement__dot success-agreement__dot--pending"></span>
        <span>Generating your purchase agreement…</span>
      </div>

      {%- comment -%} SENT — awaiting signatures {%- endcomment -%}
      <div class="success-agreement__state success-agreement__state--sent hidden" id="agr-state-sent">
        <span class="success-agreement__dot success-agreement__dot--waiting"></span>
        <div>
          <p class="success-agreement__state-label">Awaiting signatures</p>
          <p class="success-agreement__state-sub">
            Check your email for a link to sign the purchase agreement.
          </p>
          <p class="success-agreement__deadline">
            Payment deadline: <strong id="agr-deadline">–</strong>
          </p>
        </div>
        <a id="agr-sign-btn" href="/pages/purchase-agreement" class="btn btn--primary btn--sm">
          Sign agreement →
        </a>
      </div>

      {%- comment -%} BUYER_SIGNED — waiting for seller {%- endcomment -%}
      <div class="success-agreement__state success-agreement__state--waiting hidden" id="agr-state-buyer-signed">
        <span class="success-agreement__dot success-agreement__dot--waiting"></span>
        <div>
          <p class="success-agreement__state-label">You've signed — waiting for seller</p>
          <p class="success-agreement__state-sub">
            We've notified the seller. You'll receive an email once they sign.
          </p>
        </div>
      </div>

      {%- comment -%} FULLY_EXECUTED — conveyancing underway {%- endcomment -%}
      <div class="success-agreement__state success-agreement__state--executed hidden" id="agr-state-executed">
        <span class="success-agreement__dot success-agreement__dot--done"></span>
        <div>
          <p class="success-agreement__state-label">Agreement fully signed ✓</p>
          <p class="success-agreement__state-sub">
            Conveyancing has been initiated.
            Reference: <strong id="agr-conv-ref">–</strong>
          </p>
        </div>
      </div>

      {%- comment -%} DEFAULTED — payment missed {%- endcomment -%}
      <div class="success-agreement__state success-agreement__state--defaulted hidden" id="agr-state-defaulted">
        <span class="success-agreement__dot success-agreement__dot--danger"></span>
        <div>
          <p class="success-agreement__state-label" style="color:#b91c1c">Payment deadline missed</p>
          <p class="success-agreement__state-sub">
            Your deposit has been forfeited and the lot may be offered to another buyer.
            <a href="/pages/contact">Contact support</a> if you believe this is in error.
          </p>
        </div>
      </div>
    </div>

    {%- comment -%} Next steps (shown until agreement is executed) {%- endcomment -%}
    <div class="auction-success-card__next-steps" id="success-next-steps">
      <h2 class="auction-success-card__next-title" data-i18n="general.whats_next">What happens next</h2>
      <ol class="auction-success-card__steps-list">
        <li class="auction-success-card__step" id="step-sign">
          <span class="auction-success-card__step-icon" aria-hidden="true">✍️</span>
          <div>
            <p class="auction-success-card__step-title">Sign the purchase agreement</p>
            <p class="auction-success-card__step-body">
              Check your email for a signing link. Both you and the seller must sign before conveyancing begins.
            </p>
          </div>
        </li>
        <li class="auction-success-card__step">
          <span class="auction-success-card__step-icon" aria-hidden="true">💳</span>
          <div>
            <p class="auction-success-card__step-title">Pay the balance</p>
            <p class="auction-success-card__step-body" id="step-deposit-body">
              Your deposit has been applied. Arrange the remaining balance before the payment deadline.
            </p>
          </div>
        </li>
        <li class="auction-success-card__step">
          <span class="auction-success-card__step-icon" aria-hidden="true">🏠</span>
          <div>
            <p class="auction-success-card__step-title">Conveyancing &amp; handover</p>
            <p class="auction-success-card__step-body">
              Once fully signed and paid, the conveyancer will coordinate title transfer and property handover.
            </p>
          </div>
        </li>
      </ol>
    </div>

    <div class="auction-success-card__actions">
      <a href="/account" class="btn btn--primary">View my account</a>
      <a href="/pages/auctions" class="btn btn--ghost" data-i18n="general.view_all">Browse more listings</a>
    </div>

    <p class="auction-success-card__support">
      Questions? <a href="/pages/contact">Contact support</a> — we're here to help.
    </p>
  </div>

  {%- comment -%} ── LOSS / NO-RESERVE FALLBACK ── {%- endcomment -%}
  <div class="auction-loss-card hidden" id="auction-loss-card">
    <div class="auction-loss-card__icon" aria-hidden="true">😔</div>
    <h1 class="auction-loss-card__title">Better luck next time</h1>
    <p class="auction-loss-card__sub">
      You weren't the winning bidder this time.
      Any deposit you placed will be released within 24 hours.
    </p>
    <a href="/pages/auctions" class="btn btn--primary">Browse more listings</a>
  </div>

</div>

{% schema %}
{ "name": "Auction success", "settings": [] }
{% endschema %}
