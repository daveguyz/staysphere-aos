<section class="contact-section section-padding">
  <div class="page-width">
    <div class="contact-layout">
      <div class="contact-form-wrap">
        <h2>{{ section.settings.heading | default: 'Get in touch' }}</h2>
        {%- if section.settings.intro != blank -%}
          <p class="contact-intro">{{ section.settings.intro }}</p>
        {%- endif -%}
        {% form 'contact' %}
          {%- if form.posted_successfully? -%}
            <p class="contact-success">Thanks for your message — we'll be in touch soon!</p>
          {%- endif -%}
          <div class="form-field">
            <label for="contact-name">Name</label>
            <input type="text" id="contact-name" name="contact[name]" required
                   value="{{ form.name }}" autocomplete="name">
          </div>
          <div class="form-field">
            <label for="contact-email">Email</label>
            <input type="email" id="contact-email" name="contact[email]" required
                   value="{{ form.email }}" autocomplete="email">
          </div>
          <div class="form-field">
            <label for="contact-body">Message</label>
            <textarea id="contact-body" name="contact[body]" rows="5" required>{{ form.body }}</textarea>
          </div>
          <button type="submit" class="btn btn--primary">Send message</button>
        {% endform %}
      </div>
      {%- if section.settings.show_details -%}
        <div class="contact-details">
          {%- if section.settings.email != blank -%}
            <p>✉ <a href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a></p>
          {%- endif -%}
          {%- if section.settings.phone != blank -%}
            <p>📞 <a href="tel:{{ section.settings.phone }}">{{ section.settings.phone }}</a></p>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Contact form",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Get in touch" },
    { "type": "textarea", "id": "intro", "label": "Intro text" },
    { "type": "checkbox", "id": "show_details", "label": "Show contact details", "default": true },
    { "type": "text", "id": "email", "label": "Email address" },
    { "type": "text", "id": "phone", "label": "Phone number" }
  ],
  "presets": [{ "name": "Contact form" }]
}
{% endschema %}
