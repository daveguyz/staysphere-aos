<section class="how-it-works section-padding">
  <div class="page-width">
    <h2 class="section-header__title text-center">{{ section.settings.heading | default: 'How StaySphere works' }}</h2>
    <div class="how-it-works__steps">
      {%- for block in section.blocks -%}
        {%- if block.type == 'step' -%}
          <div class="hiw-step" {{ block.shopify_attributes }}>
            <div class="hiw-step__icon" aria-hidden="true">{{ block.settings.icon | default: '✦' }}</div>
            <h3 class="hiw-step__title">{{ block.settings.title }}</h3>
            <p class="hiw-step__text">{{ block.settings.text }}</p>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "How it works",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "The complete real estate platform" }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "limit": 5,
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon (emoji)", "default": "🔍" },
        { "type": "text", "id": "title", "label": "Step title", "default": "Search" },
        { "type": "textarea", "id": "text", "label": "Description" }
      ]
    }
  ],
  "presets": [
    {
      "name": "How it works",
      "blocks": [
        { "type": "step", "settings": { "icon": "🏠", "title": "List", "text": "Add your properties in minutes. Set pricing, upload photos, and publish instantly to your branded storefront." } },
        { "type": "step", "settings": { "icon": "🔨", "title": "Auction or Book", "text": "Run live English, Dutch, or sealed-bid auctions alongside traditional bookings — all from one dashboard." } },
        { "type": "step", "settings": { "icon": "💳", "title": "Close the deal", "text": "Buyers bid, deposit, and complete KYC verification in the platform. You get paid — no chasing." } }
      ]
    }
  ]
}
{% endschema %}
