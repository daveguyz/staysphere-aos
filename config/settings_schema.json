  {
    "name": "Typography",
    "settings": [
      {
        "type": "select",
        "id": "font_heading_family",
        "label": "Heading font family",
        "options": [
          {
            "value": "'Playfair Display', Georgia, serif",
            "label": "Playfair Display"
          },
          {
            "value": "'Cormorant Garamond', Georgia, serif",
            "label": "Cormorant Garamond"
          },
          {
            "value": "'Inter', sans-serif",
            "label": "Inter (sans)"
          },
          {
            "value": "'DM Sans', sans-serif",
            "label": "DM Sans"
          },
          {
            "value": "'Sora', sans-serif",
            "label": "Sora"
          },
          {
            "value": "system-ui, sans-serif",
            "label": "System default"
          }
        ],
        "default": "'Playfair Display', Georgia, serif"
      },
      {
        "type": "select",
        "id": "font_body_family",
        "label": "Body font family",
        "options": [
          {
            "value": "'Inter', system-ui, sans-serif",
            "label": "Inter"
          },
          {
            "value": "'DM Sans', system-ui, sans-serif",
            "label": "DM Sans"
          },
          {
            "value": "'Lato', system-ui, sans-serif",
            "label": "Lato"
          },
          {
            "value": "system-ui, sans-serif",
            "label": "System default"
          }
        ],
        "default": "'Inter', system-ui, sans-serif"
      },
      {
        "type": "range",
        "id": "font_body_size",
        "min": 14,
        "max": 20,
        "step": 1,
        "unit": "px",
        "label": "Base font size",
        "default": 16
      },
      {
        "type": "range",
        "id": "font_heading_scale",
        "min": 80,
        "max": 150,
        "step": 5,
        "unit": "%",
        "label": "Heading scale",
        "default": 110
      }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "range",
        "id": "page_max_width",
        "min": 960,
        "max": 1600,
        "step": 40,
        "unit": "px",
        "label": "Max page width",
        "default": 1280
      },
      {
        "type": "range",
        "id": "grid_gap",
        "min": 12,
        "max": 40,
        "step": 4,
        "unit": "px",
        "label": "Grid gap",
        "default": 24
      },
      {
        "type": "range",
        "id": "border_radius",
        "min": 0,
        "max": 24,
        "step": 2,
        "unit": "px",
        "label": "Card border radius",
        "default": 12
      },
      {
        "type": "range",
        "id": "section_padding",
        "min": 32,
        "max": 120,
        "step": 8,
        "unit": "px",
        "label": "Section vertical padding",
        "default": 64
      },
      {
        "type": "checkbox",
        "id": "show_breadcrumbs",
        "label": "Show breadcrumbs",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "sticky_header",
        "label": "Sticky header",
        "default": true
      }
    ]
  },
  {
    "name": "Buttons",
    "settings": [
      {
        "type": "range",
        "id": "btn_border_radius",
        "min": 0,
        "max": 32,
        "step": 2,
        "unit": "px",
        "label": "Button border radius",
        "default": 8
      },
      {
        "type": "select",
        "id": "btn_size",
        "label": "Button size",
        "options": [
          {
            "value": "sm",
            "label": "Small"
          },
          {
            "value": "md",
            "label": "Medium"
          },
          {
            "value": "lg",
            "label": "Large"
          }
        ],
        "default": "md"
      },
      {
        "type": "checkbox",
        "id": "btn_uppercase",
        "label": "Uppercase button text",
        "default": false
      }
    ]
  },
  {
    "name": "Property Cards",
    "settings": [
      {
        "type": "range",
        "id": "card_columns_desktop",
        "min": 2,
        "max": 4,
        "step": 1,
        "label": "Columns on desktop",
        "default": 3
      },
      {
        "type": "range",
        "id": "card_columns_tablet",
        "min": 1,
        "max": 3,
        "step": 1,
        "label": "Columns on tablet",
        "default": 2
      },
      {
        "type": "checkbox",
        "id": "card_show_trust_score",
        "label": "Show trust score badge",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "card_show_rating",
        "label": "Show star rating",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "card_show_amenities",
        "label": "Show amenity icons",
        "default": true
      },
      {
        "type": "select",
        "id": "card_image_ratio",
        "label": "Card image ratio",
        "options": [
          {
            "value": "3/2",
            "label": "3:2 (landscape)"
          },
          {
            "value": "4/3",
            "label": "4:3 (standard)"
          },
          {
            "value": "1/1",
            "label": "1:1 (square)"
          },
          {
            "value": "16/9",
            "label": "16:9 (wide)"
          }
        ],
        "default": "3/2"
      }
    ]
  },
  {
    "name": "AI Concierge",
    "settings": [
      {
        "type": "checkbox",
        "id": "concierge_enabled",
        "label": "Enable AI concierge widget",
        "default": true
