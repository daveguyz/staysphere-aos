        "default": true
      },
      {
        "type": "checkbox",
        "id": "auction_show_bid_history_realtime",
        "label": "Show real-time bid history feed",
        "default": true
      },
      {
        "type": "header",
        "content": "Search"
      },
      {
        "type": "checkbox",
        "id": "auction_search_elasticsearch",
        "label": "Use Elasticsearch for auction search (faster)",
