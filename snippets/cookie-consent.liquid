<div id="cookie-banner" class="cookie-banner hidden" role="dialog" aria-label="Cookie consent">
  <div class="cookie-banner__inner">
    <p class="cookie-banner__text">
      We use cookies to personalise your experience and remember your search preferences.
      <a href="{{ shop.privacy_policy.url }}">Privacy policy</a>
    </p>
    <div class="cookie-banner__actions">
      <button class="btn btn--primary btn--sm" id="cookie-accept">Accept all</button>
      <button class="btn btn--ghost btn--sm" id="cookie-essential">Essential only</button>
    </div>
  </div>
</div>
