<!doctype html>
<html lang="{{ request.locale.iso_code }}" data-theme-version="1.0.0">
<head>
  <meta charset="utf-8">
  {%- comment -%} Inline i18n bootstrap — sets locale context before any plugin runs {%- endcomment -%}
  <script>
    // Phase A bootstrap: pass theme locale settings to JS before plugins load
    window.ssI18nConfig = {
      autoDetect:      {{ settings.locale_auto_detect | default: true | json }},
      defaultLanguage: {{ settings.default_language | default: 'en' | json }},
      defaultTimezone: {{ settings.default_timezone | default: 'UTC' | json }},
      defaultCurrency: {{ settings.default_currency | default: 'USD' | json }},
      cdnHost:         "{{ 'x' | asset_url | remove: '/assets/x' }}",
      shopLocale:      "{{ request.locale.iso_code | default: 'en' }}"
    };
  </script>
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta name="theme-color" content="{{ settings.color_nav_bg }}">

  {% if settings.seo_structured_data %}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": {{ shop.name | json }},
      "url": {{ shop.url | json }},
      "potentialAction": {
        "@type": "SearchAction",
        "target": "{{ shop.url }}/collections/all?city={search_term_string}",
        "query-input": "required name=search_term_string"
      }
    }
    </script>
  {% endif %}

  <title>
    {%- if page_title == blank -%}{{ shop.name }}{%- else -%}{{ page_title }} — {{ shop.name }}{%- endif -%}
  </title>

  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- elsif settings.seo_meta_description != blank -%}
    <meta name="description" content="{{ settings.seo_meta_description | escape }}">
  {%- endif -%}

  <link rel="canonical" href="{{ canonical_url }}">
  <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin>
  <link rel="dns-prefetch" href="{{ settings.api_gateway_url }}">

  {% if settings.perf_preload_fonts %}
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" as="style"
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Inter:wght@300;400;500;600&display=swap">
    <link rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Inter:wght@300;400;500;600&display=swap"
      media="print" onload="this.media='all'">
    <noscript>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Inter:wght@300;400;500;600&display=swap">
    </noscript>
  {% endif %}

  {% comment %} Inject CSS custom properties from theme settings {% endcomment %}
  <style>
    :root {
      --color-primary: {{ settings.color_primary }};
      --color-primary-text: {{ settings.color_primary_text }};
      --color-bg: {{ settings.color_background }};
      --color-surface: {{ settings.color_surface }};
      --color-nav-bg: {{ settings.color_nav_bg }};
      --color-nav-text: {{ settings.color_nav_text }};
      --color-footer-bg: {{ settings.color_footer_bg }};
      --color-footer-text: {{ settings.color_footer_text }};
      --color-text: {{ settings.color_text_primary }};
      --color-text-muted: {{ settings.color_text_muted }};
      --color-border: {{ settings.color_border }};
      --color-success: {{ settings.color_success | default: '#10b981' }};
      --color-error: {{ settings.color_error | default: '#ef4444' }};
      --font-heading: {{ settings.font_heading_family }};
      --font-body: {{ settings.font_body_family }};
      --font-size-base: {{ settings.font_body_size }}px;
      --heading-scale: {{ settings.font_heading_scale | divided_by: 100.0 }};
      --page-max-width: {{ settings.page_max_width }}px;
      --grid-gap: {{ settings.grid_gap }}px;
      --radius: {{ settings.border_radius }}px;
      --btn-radius: {{ settings.btn_border_radius }}px;
      --section-padding: {{ settings.section_padding }}px;
      --card-cols-desktop: {{ settings.card_columns_desktop }};
      --card-cols-tablet: {{ settings.card_columns_tablet }};
      --card-ratio: {{ settings.card_image_ratio }};
      --concierge-fab-color: {{ settings.concierge_fab_color | default: settings.color_nav_bg }};
    }
  </style>

  {{ content_for_header }}
  {{ 'base.css' | asset_url | stylesheet_tag }}
  {{ 'theme.css' | asset_url | stylesheet_tag }}

  {% comment %} GTM / Pixel {% endcomment %}
  {% if settings.google_tag_manager_id != blank %}
    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','{{ settings.google_tag_manager_id }}');</script>
  {% endif %}
</head>

<body class="template-{{ template.name }}{% if customer %} customer-logged-in{% endif %}"
      data-api="{{ settings.api_gateway_url | default: '' }}"
      data-currency="{{ settings.default_currency }}"
      data-locale-auto-detect="{{ settings.locale_auto_detect | default: true }}"
      data-show-currency-selector="{{ settings.show_currency_selector | default: true }}"
      data-default-language="{{ settings.default_language | default: 'en' }}"
      data-default-timezone="{{ settings.default_timezone | default: 'UTC' }}"
      data-cdn-host="{{ 'x' | asset_url | remove: '/assets/x' }}"
      data-currency-symbol="{{ settings.default_currency_symbol }}"
      data-mock="{{ settings.api_mock_mode }}"
      data-feature-bookings="{{ settings.feature_bookings }}"
      data-feature-payments="{{ settings.feature_payments }}"
      data-feature-ai="{{ settings.feature_ai_concierge }}"
      data-feature-messaging="{{ settings.messaging_enabled }}"
      data-feature-reviews="{{ settings.feature_reviews }}"
      data-feature-host-dashboard="{{ settings.feature_host_dashboard }}"
      data-feature-auctioneer-dashboard="{{ settings.feature_auctioneer_dashboard | default: true }}"
      data-customer-tags="{{ customer.tags | join: ',' | default: '' }}"
      data-feature-pricing="{{ settings.feature_dynamic_pricing }}"
      data-feature-trip-builder="{{ settings.feature_trip_builder }}"
      data-feature-auctions="{{ settings.feature_auctions }}"
      data-feature-live-bidding="{{ settings.feature_live_bidding }}"
      data-feature-proxy-bidding="{{ settings.feature_proxy_bidding }}"
      data-feature-dutch="{{ settings.feature_dutch_auction }}"
      data-feature-reverse="{{ settings.feature_reverse_auction }}"
      data-feature-sealed="{{ settings.feature_sealed_bid }}"
      data-feature-deposits="{{ settings.feature_auction_deposits }}"
      data-feature-auction-kyc="{{ settings.feature_auction_kyc }}"
      data-feature-livestream="{{ settings.feature_auction_livestream }}"
      data-auction-ws="{{ settings.auction_websocket_url | default: '' }}"
      data-auction-livestream-provider="{{ settings.auction_livestream_provider }}"
      data-auction-show-viewers="{{ settings.auction_show_viewer_count }}"
      data-auction-bid-history="{{ settings.auction_show_bid_history_realtime }}"
      data-auction-use-es="{{ settings.auction_search_elasticsearch }}"
      data-customer-id="{{ customer.id | default: '' }}"
      data-customer-email="{{ customer.email | default: '' }}">
  {%- render 'app-setup-banner' -%}

  {% if settings.google_tag_manager_id != blank %}
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id={{ settings.google_tag_manager_id }}" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  {% endif %}

  {% render 'skip-to-content' %}

  {% section 'announcement-bar' %}

  <div id="site-header-wrapper" class="{% if settings.sticky_header %}site-header--sticky{% endif %}">
    {% section 'header' %}
  </div>

  {% render 'notification-banner' %}

  <main id="main-content" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  {% comment %} AI Concierge — only rendered if feature flag is on {% endcomment %}
  {% if settings.feature_ai_concierge and settings.concierge_enabled %}
    {% render 'ai-concierge' %}
  {% endif %}

  {% comment %} Real-time notification bell — shown to logged-in users {% endcomment %}
  {% if customer and settings.notifications_enabled %}
    {% render 'notification-bell' %}
  {% endif %}

  {% comment %} Messaging badge — shown to logged-in users {% endcomment %}
  {% if customer and settings.messaging_enabled and settings.feature_host_dashboard %}
    {% render 'messaging-badge' %}
  {% endif %}

  {% comment %} Cookie consent {% endcomment %}
  {% render 'cookie-consent' %}

  {% comment %} Global modals {% endcomment %}
  {% render 'modal-backdrop' %}
  <div id="global-toast-container" aria-live="polite" aria-atomic="true"></div>


  {% comment %} Page-specific plugins {% endcomment %}
  {% if template.name == 'collection' %}
    {%- if settings.show_currency_selector != false -%}
      {{ 'plugin-i18n.js' | asset_url | script_tag }}
    {%- endif -%}
    {{ 'plugin-search.js' | asset_url | script_tag }}
  {% endif %}
  {% if template.name == 'product' %}
    {{ 'plugin-product.js' | asset_url | script_tag }}
  {% endif %}
  {% if template.name == 'page' and page.handle contains 'auction' %}
    {{ 'plugin-auction.js' | asset_url | script_tag }}
    {% if page.handle contains 'auction-room' %}
      {{ 'plugin-auction-room.js' | asset_url | script_tag }}
    {% endif %}
  {% endif %}
  {% if template.name == 'customers' or template.name == 'account'
     or page.handle == 'kyc' or page.handle == 'deposit'
     or page.handle == 'auction-success' %}
    {{ 'plugin-auth.js' | asset_url | script_tag }}
  {% endif %}
  {% if page.handle == 'booking-checkout' or page.handle == 'booking-success' %}
    {{ 'plugin-booking.js' | asset_url | script_tag }}
  {% endif %}
  {% if page.handle == 'host-dashboard' or page.handle == 'property-create' %}
    {{ 'plugin-host.js' | asset_url | script_tag }}
  {% endif %}
  {% if page.handle == 'messages' %}
    {{ 'plugin-messaging.js' | asset_url | script_tag }}
  {% endif %}
  {% if page.handle == 'admin' %}
    {{ 'plugin-admin.js' | asset_url | script_tag }}
  {% endif %}
  {% if page.handle == 'auctioneer-dashboard' %}
    {{ 'plugin-auctioneer.js' | asset_url | script_tag }}
  {% endif %}

  {{ 'theme.js' | asset_url | script_tag }}
  {%- if settings.show_currency_selector != false -%}
    {{ 'plugin-locale-selector.js' | asset_url | script_tag }}
  {%- endif -%}
</body>
</html>
