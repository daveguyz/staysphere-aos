  {
    "name": "Auction OS",
    "settings": [
      {
        "type": "header",
        "content": "Auction Feature Flags"
      },
      {
        "type": "checkbox",
        "id": "feature_auctions",
        "label": "Enable Auction OS",
        "default": false,
        "info": "Enable once auction-service is deployed"
      },
      {
        "type": "checkbox",
        "id": "feature_live_bidding",
        "label": "Enable live bidding (WebSocket)",
        "default": false
      },
      {
        "type": "checkbox",
        "id": "feature_proxy_bidding",
        "label": "Enable proxy bidding",
        "default": false
      },
      {
        "type": "checkbox",
        "id": "feature_dutch_auction",
        "label": "Enable Dutch auctions",
        "default": false
      },
      {
        "type": "checkbox",
        "id": "feature_reverse_auction",
        "label": "Enable reverse auctions",
        "default": false
      },
      {
        "type": "checkbox",
        "id": "feature_sealed_bid",
        "label": "Enable sealed-bid auctions",
        "default": false
      },
      {
        "type": "checkbox",
        "id": "feature_auction_deposits",
        "label": "Enable deposit-gated bidding",
        "default": false
      },
      {
        "type": "checkbox",
        "id": "feature_auction_kyc",
        "label": "Enable KYC-gated bidding",
        "default": false
      },
      {
        "type": "checkbox",
        "id": "feature_auction_livestream",
        "label": "Enable auction livestream",
        "default": false
      },
      {
        "type": "header",
        "content": "Auction Configuration"
      },
      {
        "type": "text",
        "id": "auction_websocket_url",
        "label": "Auction WebSocket URL",
        "info": "e.g. wss://api.staysphere.com/ws/auction"
      },
      {
        "type": "range",
        "id": "auction_anti_snipe_minutes",
        "min": 1,
        "max": 30,
        "step": 1,
        "label": "Default anti-snipe extension (minutes)",
        "default": 5
      },
      {
        "type": "text",
        "id": "auction_currency_symbol",
        "label": "Auction currency symbol",
        "default": "$"
      },
      {
        "type": "header",
        "content": "KYC & Fraud"
      },
      {
        "type": "text",
        "id": "stripe_kyc_publishable_key",
        "label": "Stripe publishable key (KYC)",
        "info": "Used by the KYC form to init Stripe Identity"
      },
      {
        "type": "checkbox",
        "id": "feature_fraud_ai",
        "label": "Enable AI fraud detection",
        "default": false,
        "info": "Requires ANTHROPIC_API_KEY configured on the server"
      },
      {
        "type": "header",
        "content": "Auction Types Visible on Storefront"
      },
      {
        "type": "checkbox",
        "id": "show_dutch_auction_tab",
        "label": "Show Dutch auction tab",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "show_reverse_auction_tab",
        "label": "Show reverse auction tab",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "show_sealed_bid_tab",
        "label": "Show sealed bid tab",
        "default": true
      },
      {
        "type": "header",
        "content": "Livestream"
      },
      {
        "type": "select",
        "id": "auction_livestream_provider",
