<div class="page-hero{% if section.settings.image != blank %} page-hero--has-image{% endif %}"
     {% if section.settings.image != blank %}
     style="background-image: url('{{ section.settings.image | image_url: width: 1600 }}')"
     {% endif %}>
  <div class="page-hero__overlay"></div>
  <div class="page-hero__content page-width">
    <h1 class="page-hero__title">{{ page.title }}</h1>
    {%- if section.settings.subtitle != blank -%}
      <p class="page-hero__subtitle">{{ section.settings.subtitle }}</p>
    {%- endif -%}
  </div>
</div>
{% schema %}
{
  "name": "Page hero",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Background image" },
    { "type": "text", "id": "subtitle", "label": "Subtitle" }
  ]
}
{% endschema %}
