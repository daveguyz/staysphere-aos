[
  {
    "name": "theme_info",
    "theme_name": "StaySphere AOS",
    "theme_version": "1.0.0",
    "theme_author": "StaySphere",
    "theme_documentation_url": "https://docs.staysphere.com/theme",
    "theme_support_url": "https://support.staysphere.com",
    "settings": []
  },
  {
    "name": "Brand",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo"
      },
      {
        "type": "image_picker",
        "id": "logo_dark",
        "label": "Dark mode logo"
      },
      {
        "type": "range",
        "id": "logo_width",
        "min": 80,
        "max": 320,
        "step": 8,
        "unit": "px",
        "label": "Logo width",
        "default": 160
      },
      {
        "type": "text",
        "id": "brand_name",
        "label": "Brand name",
        "default": "StaySphere"
      },
      {
        "type": "richtext",
        "id": "brand_tagline",
        "label": "Brand tagline"
      }
    ]
  },
  {
