      {
        "type": "color",
        "id": "concierge_fab_color",
        "label": "Concierge button color",
        "default": "#1a1a2e"
      },
      {
        "type": "select",
        "id": "concierge_position",
        "label": "Concierge button position",
        "options": [
          {
            "value": "bottom-right",
            "label": "Bottom right"
          },
          {
            "value": "bottom-left",
            "label": "Bottom left"
          }
        ],
        "default": "bottom-right"
      }
    ]
  },
  {
